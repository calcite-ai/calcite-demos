---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { articleJsonLd, breadcrumbJsonLd } from '../../lib/schema';

const post = await getEntry('guides', 'seinengoiken');
if (!post) throw new Error('guide missing');
const { Content } = await render(post);
const path = '/guides/seinengoiken/';
const jsonLd = [
  articleJsonLd({
    title: post.data.title,
    description: post.data.meta_description,
    path,
    datePublished: post.data.published_date,
  }),
  breadcrumbJsonLd([
    { name: '制度解説' },
    { name: post.data.title, path },
  ]),
];
---

<BaseLayout title={post.data.title} description={post.data.meta_description} ogType="article" jsonLd={jsonLd}>
  <PageHero title={post.data.title} lead={post.data.meta_description} crumbs={[{ label: '制度解説' }, { label: post.data.title }]} />
  <article class="mx-auto max-w-3xl px-4 py-12">
    <div class="mb-4 rounded-xl bg-accent-soft px-4 py-3 text-sm text-brand-dark">制度解説は誤情報が不利益につながり得ます。本ページはデモであり、公開前に専門家確認が必要です。</div>
    <div class="prose-demo rounded-2xl border border-brand/10 bg-white p-6 md:p-10"><Content /></div>
  </article>
</BaseLayout>
