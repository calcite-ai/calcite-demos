---
import { withBase } from '../../lib/site';
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { articleJsonLd, breadcrumbJsonLd } from '../../lib/schema';

export async function getStaticPaths() {
  const cases = await getCollection('cases', ({ data }) => data.status === 'published');
  return cases.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const path = `/cases/${post.id}/`;
const jsonLd = [
  articleJsonLd({
    title: post.data.title,
    description: post.data.meta_description,
    path,
    datePublished: post.data.published_date,
  }),
  breadcrumbJsonLd([
    { name: 'ご相談・解決事例集', path: '/cases/' },
    { name: post.data.title, path },
  ]),
];
---

<BaseLayout title={post.data.title} description={post.data.meta_description} ogType="article" jsonLd={jsonLd}>
  <PageHero
    title={post.data.title}
    lead={post.data.meta_description}
    crumbs={[{ label: 'ご相談・解決事例集', href: '/cases/' }, { label: '事例詳細' }]}
  />
  <article class="mx-auto max-w-3xl px-4 py-12">
    <div class="mb-8 flex flex-wrap gap-2 text-xs">
      <span class="rounded-full bg-brand-light px-2.5 py-1 font-medium text-brand">{post.data.category}</span>
      <span class="rounded-full border border-brand/15 px-2.5 py-1 text-muted">{post.data.source}</span>
    </div>
    <div class="prose-demo rounded-2xl border border-brand/10 bg-white p-6 md:p-10">
      <Content />
    </div>
    <p class="mt-8"><a href={withBase("/cases/")} class="text-brand font-medium underline underline-offset-4">事例一覧へ戻る</a></p>
  </article>
</BaseLayout>
