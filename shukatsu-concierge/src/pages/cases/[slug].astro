---
import { withBase } from '../../lib/site';
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { articleJsonLd, breadcrumbJsonLd } from '../../lib/schema';
import { categoryToSlug } from '../../lib/cases';

export async function getStaticPaths() {
  const cases = await getCollection('cases', ({ data }) => data.status === 'published');
  return cases.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const path = `/cases/${post.id}/`;
const categoryPath = `/cases/category/${categoryToSlug(post.data.category)}/`;
const jsonLd = [
  articleJsonLd({
    title: post.data.title,
    description: post.data.meta_description,
    path,
    datePublished: post.data.published_date,
  }),
  breadcrumbJsonLd([
    { name: 'ご相談・解決事例集', path: '/cases/' },
    { name: post.data.category, path: categoryPath },
    { name: post.data.title, path },
  ]),
];
---

<BaseLayout title={post.data.title} description={post.data.meta_description} ogType="article" jsonLd={jsonLd}>
  <PageHero
    title={post.data.title}
    lead={post.data.meta_description}
    crumbs={[
      { label: 'ご相談・解決事例集', href: '/cases/' },
      { label: post.data.category, href: categoryPath },
      { label: post.data.title },
    ]}
  />
  <article class="mx-auto max-w-3xl px-4 py-12">
    <div class="mb-8 flex flex-wrap gap-2 text-xs">
      <a
        href={withBase(categoryPath)}
        class="rounded-full bg-brand-light px-2.5 py-1 font-medium text-brand hover:bg-accent-soft transition"
      >
        {post.data.category}
      </a>
      <span class="rounded-full border border-brand/15 px-2.5 py-1 text-muted">相談元：{post.data.source}</span>
      <time class="rounded-full border border-brand/15 px-2.5 py-1 text-muted" datetime={post.data.published_date.toISOString()}>
        {post.data.published_date.toISOString().slice(0, 10)}
      </time>
    </div>
    <div class="prose-demo rounded-2xl border border-brand/10 bg-white p-6 md:p-10">
      <Content />
    </div>
    <p class="mt-8 text-xs text-muted">※個人が特定される実在情報は含みません。現場で起きやすい相談を再構成した想定事例です。</p>
    <p class="mt-6 flex flex-wrap gap-4">
      <a href={withBase(categoryPath)} class="text-brand font-medium underline underline-offset-4">
        「{post.data.category}」の事例一覧
      </a>
      <a href={withBase('/cases/')} class="text-brand font-medium underline underline-offset-4">事例一覧へ戻る</a>
    </p>
  </article>
</BaseLayout>
