---
import { breadcrumbJsonLd } from '../../lib/schema';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import Section from '../../components/Section.astro';

const desc = '地域包括・ケアマネ・病院MSW・ご本人からの相談を、相談内容→課題→対応→結果→ポイントで紹介します。掲載はすべてデモ用の架空事例です。';
const all = (await getCollection('cases', ({ data }) => data.status === 'published'))
  .sort((a, b) => b.data.published_date.valueOf() - a.data.published_date.valueOf());
const categories = ['すべて', '身元保証', '死後事務', '相続', '生活支援', 'その他'];
const jsonLd = [breadcrumbJsonLd([{ name: 'ご相談・解決事例集', path: '/cases/' }])];
---

<BaseLayout title="ご相談・解決事例集" jsonLd={jsonLd} description={desc}>
  <PageHero title="ご相談・解決事例集" lead={desc} crumbs={[{ label: 'ご相談・解決事例集' }]} />

  <Section eyebrow="Cases" title="事例一覧">
    <div class="mb-6 flex flex-wrap gap-2" role="group" aria-label="カテゴリ絞り込み">
      {categories.map((cat) => (
        <button
          type="button"
          data-filter={cat}
          class="filter-btn rounded-full border border-brand/20 bg-white px-4 py-2 text-sm text-brand-dark hover:bg-brand-light transition aria-[current=true]:bg-brand aria-[current=true]:text-white aria-[current=true]:border-brand"
          aria-current={cat === 'すべて' ? 'true' : undefined}
        >{cat}</button>
      ))}
    </div>

    <div class="grid gap-4" id="case-list">
      {all.map((item) => (
        <a
          href={`/cases/${item.id}/`}
          data-category={item.data.category}
          class="case-card block rounded-2xl border border-brand/10 bg-white p-5 hover:border-brand hover:shadow-sm transition"
        >
          <div class="flex flex-wrap items-center gap-2 text-xs">
            <span class="rounded-full bg-brand-light px-2.5 py-1 font-medium text-brand">{item.data.category}</span>
            <span class="text-muted">{item.data.source}</span>
            <span class="text-muted">{item.data.published_date.toISOString().slice(0, 10)}</span>
          </div>
          <h2 class="mt-3 text-lg font-bold text-brand-dark">{item.data.title}</h2>
          <p class="mt-2 text-sm text-muted line-clamp-2">{item.data.meta_description}</p>
        </a>
      ))}
    </div>
    <p class="mt-8 text-xs text-muted">※実在の相談事例・個人情報は使用していません。上司提案用のダミーです。</p>
  </Section>
</BaseLayout>

<script>
  const buttons = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.case-card');
  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const cat = btn.getAttribute('data-filter');
      buttons.forEach((b) => b.setAttribute('aria-current', b === btn ? 'true' : 'false'));
      cards.forEach((card) => {
        const show = cat === 'すべて' || card.getAttribute('data-category') === cat;
        card.classList.toggle('hidden', !show);
      });
    });
  });
</script>
