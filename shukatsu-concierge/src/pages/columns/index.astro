---
import { breadcrumbJsonLd, itemListJsonLd } from '../../lib/schema';
import { getCategoryStats, getPublishedColumns } from '../../lib/columns';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import Section from '../../components/Section.astro';
import AnswerLead from '../../components/AnswerLead.astro';
import ColumnCategoryNav from '../../components/ColumnCategoryNav.astro';
import ColumnPostList from '../../components/ColumnPostList.astro';

const desc = '終活・身元保証・制度の見方など、ご本人・ご家族・専門職向けの解説記事（自社ブログ）。検索やAIに引用されやすいよう、各記事の冒頭で結論を示します。カテゴリーから関連記事を探せます。';
const posts = await getPublishedColumns();
const categories = getCategoryStats(posts);
const jsonLd = [
  breadcrumbJsonLd([{ name: 'コラム', path: '/columns/' }]),
  itemListJsonLd(
    'コラム記事一覧',
    posts.map((post) => ({
      name: post.data.title,
      path: `/columns/${post.id}/`,
      description: post.data.meta_description,
    })),
    '/columns/',
  ),
];
---

<BaseLayout title="コラム" jsonLd={jsonLd} description={desc}>
  <PageHero title="コラム" lead={desc} crumbs={[{ label: 'コラム' }]} />

  <div class="mx-auto max-w-6xl px-4 pt-10 space-y-8">
    <AnswerLead title="コラムについて">
      <p>
        終活・身元保証・制度の見方など、高齢者ご本人・ご家族・専門職向けの解説記事を掲載します。検索やAIに引用されやすいよう、各記事の冒頭で結論を示します。気になるテーマはカテゴリーから絞り込めます。
      </p>
    </AnswerLead>

    <div>
      <p class="mb-3 text-sm font-medium text-brand-dark">カテゴリー</p>
      <ColumnCategoryNav categories={categories} />
    </div>
  </div>

  <Section eyebrow="Articles" title="記事一覧">
    <ColumnPostList posts={posts} />
  </Section>
</BaseLayout>
