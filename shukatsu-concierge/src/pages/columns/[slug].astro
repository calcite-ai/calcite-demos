---
import { withBase } from '../../lib/site';
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { articleJsonLd, breadcrumbJsonLd } from '../../lib/schema';
import { categoryToSlug } from '../../lib/columns';

export async function getStaticPaths() {
  const columns = await getCollection('columns', ({ data }) => data.status === 'published');
  return columns.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const path = `/columns/${post.id}/`;
const categoryPath = `/columns/category/${categoryToSlug(post.data.category)}/`;
const jsonLd = [
  articleJsonLd({
    title: post.data.title,
    description: post.data.meta_description,
    path,
    datePublished: post.data.published_date,
    image: post.data.og_image,
  }),
  breadcrumbJsonLd([
    { name: 'コラム', path: '/columns/' },
    { name: post.data.category, path: categoryPath },
    { name: post.data.title, path },
  ]),
];
---

<BaseLayout title={post.data.title} description={post.data.meta_description} ogType="article" jsonLd={jsonLd}>
  <PageHero
    title={post.data.title}
    lead={post.data.meta_description}
    crumbs={[
      { label: 'コラム', href: '/columns/' },
      { label: post.data.category, href: categoryPath },
      { label: post.data.title },
    ]}
  />
  <article class="mx-auto max-w-3xl px-4 py-12">
    <div class="mb-6 flex flex-wrap gap-2 text-xs text-muted">
      <a
        href={withBase(categoryPath)}
        class="rounded-full bg-accent-soft px-2.5 py-1 text-brand-dark font-medium hover:bg-brand-light transition"
      >
        {post.data.category}
      </a>
      <time datetime={post.data.published_date.toISOString()}>{post.data.published_date.toISOString().slice(0, 10)}</time>
    </div>
    <div class="prose-demo rounded-2xl border border-brand/10 bg-white p-6 md:p-10">
      <Content />
    </div>
    <p class="mt-8 flex flex-wrap gap-4">
      <a href={withBase(categoryPath)} class="text-brand font-medium underline underline-offset-4">
        「{post.data.category}」の記事一覧
      </a>
      <a href={withBase("/columns/")} class="text-brand font-medium underline underline-offset-4">コラム一覧へ戻る</a>
    </p>
  </article>
</BaseLayout>
