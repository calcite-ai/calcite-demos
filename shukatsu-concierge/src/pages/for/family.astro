---
import AudiencePage from '../../components/AudiencePage.astro';
---

<AudiencePage
  label="ご家族向け"
  slug="family"
  lead="遠方でも、親の入院・施設・死後の手続きを任せられる窓口を。"
  definition="終活コンシェルジュは、ご家族に代わって高齢者の身元保証・生活支援・死後事務を引き受ける一般社団法人です。遠方に住むご家族でも、相談窓口をひとつにまとめられます。"
  pains={['遠方に住んでいて、急な入院連絡に対応しきれない', '身元保証人を頼める親族が近くにいない', '死後の手続きまで含めて整理しておきたい']}
  offers={['無料相談で状況を整理', '必要なら身元保証・死後事務の提案', '施設・病院との連絡窓口を一本化']}
  faqs={[
    { question: '家族がいても契約できますか？', answer: 'できます。遠方・多忙などで日常の支えを頼めない場合にも、ご家族と連携しながら支援します。' },
    { question: 'まずは何から相談すればよいですか？', answer: '入院・施設入所の身元保証、見守り、死後の手続きなど、いま困っていることを整理してお問い合わせください。初回相談は無料です。' },
  ]}
/>
