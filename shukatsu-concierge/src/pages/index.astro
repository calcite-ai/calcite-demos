---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import AnswerLead from '../components/AnswerLead.astro';
import PhotoFrame from '../components/PhotoFrame.astro';
import { site, services, worries, audiencePages, flowSteps, withBase } from '../lib/site';
import {
  organizationJsonLd,
  webSiteJsonLd,
  professionalServiceJsonLd,
} from '../lib/schema';

const jsonLd = [
  organizationJsonLd(),
  webSiteJsonLd(),
  professionalServiceJsonLd(),
];
---

<BaseLayout title="ご高齢者と関係者のための支援・相談窓口" description={site.description} jsonLd={jsonLd}>
  <section class="relative min-h-[72vh] overflow-hidden bg-brand-dark text-white">
    <img
      src={withBase("/images/hero/トップ_活動風景.jpg")}
      alt="終活コンシェルジュの活動風景"
      class="absolute inset-0 h-full w-full object-cover"
    />
    <div class="absolute inset-0 bg-[linear-gradient(105deg,rgba(20,45,38,0.92)_0%,rgba(20,45,38,0.72)_45%,rgba(20,45,38,0.35)_100%)]"></div>
    <div class="relative mx-auto flex min-h-[72vh] max-w-6xl flex-col justify-center px-4 py-20">
      <p class="text-accent text-sm tracking-[0.2em] font-medium">THE CONCIERGE FOR LIFE'S FINAL CHAPTER</p>
      <h1 class="mt-4 max-w-3xl text-[1.85rem] sm:text-4xl md:text-5xl font-bold leading-[1.35] tracking-tight">
        身元保証から死後事務まで、<br class="hidden sm:block" />窓口ひとつで支える。
      </h1>
      <p class="mt-6 max-w-xl text-white/90 text-[15px] md:text-base leading-relaxed">
        1,000件を超える相談実績を活かし、高齢者ご本人・ご家族・病院・地域包括・ケアマネの悩みを一括サポートします。
      </p>
      <div class="mt-9 flex flex-wrap gap-3">
        <a href={withBase("/contact/")} class="rounded-full bg-accent px-7 py-3.5 text-sm font-bold text-brand-dark hover:brightness-105 transition">無料で相談する</a>
        <a href={withBase("/service/")} class="rounded-full border border-white/50 px-7 py-3.5 text-sm font-medium text-white hover:bg-white/10 transition">サービスを見る</a>
      </div>
      <p class="mt-8 text-xs text-white/60">高齢者等終身サポート事業者ガイドライン遵守　／　全国高齢者支援団体連合会 参画</p>
    </div>
  </section>

  <div class="mx-auto max-w-6xl px-4 py-10">
    <AnswerLead title="終活コンシェルジュとは（要約）">
      <p>
        一般社団法人終活コンシェルジュは、高齢者の身元保証・生活支援・死後事務を窓口ひとつで支える終活の総合相談窓口です。ご本人・ご家族だけでなく、地域包括支援センター・ケアマネジャー・病院MSWからの相談にも対応します。
      </p>
    </AnswerLead>
  </div>

  <section class="border-b border-brand/10 bg-white">
    <div class="mx-auto max-w-6xl px-4 py-12 md:py-16">
      <p class="text-center text-sm md:text-base">
        <a href="https://shushin-support.or.jp" class="font-semibold text-brand underline underline-offset-4 hover:text-brand-dark" target="_blank" rel="noopener noreferrer">
          『一般社団法人全国高齢者支援団体連合会』に参画しています。
        </a>
      </p>
      <p class="mt-6 text-center">
        <a href="https://www.youtube.com/watch?v=k1L2JM7SV_M" class="text-sm md:text-base font-bold text-brand hover:text-brand-dark" target="_blank" rel="noopener noreferrer">
          【この度6月19日に羽鳥慎一のモーニングショーにて紹介されました。】
        </a>
      </p>
      <div class="mx-auto mt-6 aspect-video max-w-3xl overflow-hidden rounded-2xl shadow-md ring-1 ring-brand/10">
        <iframe
          class="h-full w-full"
          src="https://www.youtube.com/embed/k1L2JM7SV_M"
          title="「住む家がない」高齢者困惑　年齢理由に入居拒否　相談から転居までの支援サービスも【羽鳥慎一モーニングショー】(2026年6月19日)"
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          referrerpolicy="strict-origin-when-cross-origin"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </section>

  <section class="relative overflow-hidden border-y border-brand/10 bg-[#f4f1ea]">
    <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top,_rgba(47,93,80,0.08),_transparent_55%)]"></div>
    <div class="relative mx-auto max-w-4xl px-4 py-12 md:py-14 text-center">
      <p class="inline-flex items-center gap-2 rounded-full border border-accent/40 bg-white/80 px-4 py-1.5 text-xs font-semibold tracking-wide text-brand-dark">
        <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
        ガイドライン遵守
      </p>
      <p class="mt-5 text-[15px] md:text-base font-bold leading-relaxed text-brand-dark">
        一般社団法人終活コンシェルジュは【高齢者等終身サポート事業者ガイドライン】を遵守しております。
      </p>
      <div class="mt-6 space-y-4 text-[14px] md:text-[15px] leading-relaxed text-muted text-left sm:text-center">
        <p>
          身寄りがない、家族がいても身近に頼れる人がいないなどの理由から、高齢者の「身元保証サービス」「死後事務委任サービス」の需要が年々増加しており、それらのサービスを提供する事業者も増えています。
        </p>
        <p>
          終身にわたるサービスを、安心安全にご利用いただくために、令和6年6月、政府より「高齢者等終身サポート事業者ガイドライン」が発表されました。
        </p>
        <p>一般社団法人終活コンシェルジュは、このガイドラインを遵守しております。</p>
        <p>
          ひとりでも多くのご利用者様に、安心安全なサービスを提供できるよう、ガイドラインの徹底と品質向上に努めてまいります。
        </p>
      </div>
      <div class="mt-8 rounded-2xl border border-brand/10 bg-white/90 p-5 md:p-6 text-left shadow-sm">
        <p class="text-sm font-semibold text-brand-dark">政府の公式資料（PDF）</p>
        <ul class="mt-3 space-y-2 text-sm md:text-[15px]">
          <li>
            <a
              class="font-medium text-brand underline underline-offset-4 hover:text-brand-dark"
              href="https://www.caa.go.jp/policies/policy/consumer_policy/caution/caution_037/assets/consumer_policy_cms102_240618_03.pdf"
              target="_blank"
              rel="noopener noreferrer"
            >高齢者等終身サポート事業者ガイドライン（主なポイント）</a>
          </li>
          <li>
            <a
              class="font-medium text-brand underline underline-offset-4 hover:text-brand-dark"
              href="https://www.cao.go.jp/kodoku_koritsu/torikumi/suishinhonbu/dai2/pdf/siryou2-2.pdf"
              target="_blank"
              rel="noopener noreferrer"
            >高齢者等終身サポート事業者ガイドライン（全文）</a>
          </li>
          <li>
            <a
              class="font-medium text-brand underline underline-offset-4 hover:text-brand-dark"
              href="https://www.caa.go.jp/policies/policy/consumer_policy/caution/caution_037/assets/consumer_policy_cms102_240618_02.pdf"
              target="_blank"
              rel="noopener noreferrer"
            >チェックリスト</a>
          </li>
        </ul>
        <p class="mt-5 text-sm font-semibold text-brand-dark">チェックリストへの答え＝弊社の取組み</p>
        <p class="mt-2 text-[13px] md:text-sm text-muted leading-relaxed">
          チェックリストは「確認項目」、弊社の取組みは「その項目にどう応えているか」です。対応表で並べてご覧いただけます。
        </p>
        <p class="mt-3">
          <a
            class="inline-flex rounded-full bg-brand px-5 py-2.5 text-sm font-medium text-white hover:bg-brand-dark transition"
            href={withBase('/guideline/')}
          >弊社の取組み（チェックリスト対応表）を見る</a>
        </p>
      </div>
    </div>
  </section>

  <Section eyebrow="こんなお悩みはありませんか" title="一人で抱え込まなくて大丈夫です" lead="ご本人からの相談はもちろん、医療ソーシャルワーカーや地域包括支援センター、ケアマネジャーからのご相談も多数いただいています。">
    <ul class="grid gap-3 sm:grid-cols-2">
      {worries.map((w) => (
        <li class="flex gap-3 rounded-2xl border border-brand/10 bg-white p-5 shadow-sm">
          <span class="mt-1 h-2.5 w-2.5 shrink-0 rounded-full bg-accent"></span>
          <span class="text-[15px] text-ink/90">{w}</span>
        </li>
      ))}
    </ul>
  </Section>

  <Section class="bg-white border-y border-brand/5" eyebrow="Service" title="三つの柱で、生涯を支えます" lead="生活上のお困りごとから、万が一の保証人まで。「家族のように見守る安心」を、一人ひとりに合わせたプランで。">
    <div class="grid gap-6 md:grid-cols-3">
      {services.map((s) => (
        <a href={withBase(s.href)} class="group overflow-hidden rounded-2xl border border-brand/10 bg-white hover:border-brand/30 hover:shadow-md transition">
          <PhotoFrame src={s.image} alt={s.name} class="h-40" />
          <div class="p-5">
            <h3 class="text-lg font-bold text-brand-dark group-hover:text-brand">{s.name}</h3>
            <p class="mt-2 text-sm text-muted leading-relaxed">{s.summary}</p>
            <span class="mt-4 inline-block text-sm font-medium text-brand">詳しく見る →</span>
          </div>
        </a>
      ))}
    </div>
    <div class="mt-8 text-center">
      <a href={withBase("/service/")} class="inline-flex rounded-full bg-brand px-6 py-3 text-sm font-medium text-white hover:bg-brand-dark transition">サービス一覧・料金を見る</a>
    </div>
  </Section>

  <Section eyebrow="Flow" title="ご契約までの流れ" lead="まずは無料相談から。無理な勧誘はいたしません。">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {flowSteps.map((f) => (
        <div class="overflow-hidden rounded-2xl bg-white border border-brand/10">
          <PhotoFrame src={f.image} alt={f.title} class="h-36" />
          <div class="p-4">
            <p class="text-xs font-semibold tracking-wide text-accent">STEP {f.step}</p>
            <h3 class="mt-1 font-bold text-brand-dark">{f.title}</h3>
            <p class="mt-2 text-sm text-muted leading-relaxed">{f.body}</p>
          </div>
        </div>
      ))}
    </div>
    <p class="mt-6"><a href={withBase("/flow/")} class="text-brand font-medium underline underline-offset-4">ご契約の流れを詳しく →</a></p>
  </Section>

  <Section class="bg-brand-light/50" eyebrow="For You" title="あなたに合わせた入口" lead="ご本人・ご家族だけでなく、現場の専門職の方にも使いやすい導線を用意しました。">
    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {audiencePages.map((p) => (
        <a href={withBase(p.href)} class="rounded-2xl border border-brand/10 bg-white p-5 hover:border-brand transition">
          <h3 class="font-bold text-brand-dark">{p.label}</h3>
          <p class="mt-2 text-sm text-muted">{p.lead}</p>
        </a>
      ))}
    </div>
    <div class="mt-6 flex flex-wrap gap-4 text-sm">
      <a href={withBase("/guides/seinengoiken/")} class="text-brand underline underline-offset-4">成年後見制度との違い</a>
      <a href={withBase("/guides/kazoku-shintaku/")} class="text-brand underline underline-offset-4">家族信託との違い</a>
      <a href={withBase("/faq/")} class="text-brand underline underline-offset-4">よくある質問</a>
      <a href={withBase("/dancing/")} class="text-brand underline underline-offset-4">シニア社交ダンス「踊活」</a>
    </div>
  </Section>
</BaseLayout>
