---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import Section from '../../components/Section.astro';
import { faqPageJsonLd, breadcrumbJsonLd } from '../../lib/schema';

const desc = '身元保証・死後事務・ご契約・専門職連携など、よくある質問にお答えします。';
const faqs = (await getCollection('faq', ({ data }) => data.status === 'published'))
  .sort((a, b) => a.data.order - b.data.order);
const categories = ['すべて', ...Array.from(new Set(faqs.map((f) => f.data.category)))];

const jsonLd = [
  faqPageJsonLd(
    faqs.map((f) => ({
      question: f.data.question,
      answer: f.body,
    })),
  ),
  breadcrumbJsonLd([{ name: 'よくある質問', path: '/faq/' }]),
];
---

<BaseLayout title="よくある質問" description={desc} jsonLd={jsonLd}>
  <PageHero title="よくある質問" lead={desc} crumbs={[{ label: 'よくある質問' }]} />

  <Section eyebrow="FAQ" title="カテゴリから探す">
    <div class="mb-6 flex flex-wrap gap-2" role="group" aria-label="FAQカテゴリ">
      {categories.map((cat) => (
        <button
          type="button"
          data-filter={cat}
          class="faq-filter rounded-full border border-brand/20 bg-white px-4 py-2 text-sm hover:bg-brand-light transition aria-[current=true]:bg-brand aria-[current=true]:text-white"
          aria-current={cat === 'すべて' ? 'true' : undefined}
        >{cat}</button>
      ))}
    </div>

    <div class="space-y-3" id="faq-list">
      {faqs.map((f) => (
        <details
          class="faq-item group rounded-2xl border border-brand/10 bg-white px-5 py-4 open:shadow-sm"
          data-category={f.data.category}
        >
          <summary class="cursor-pointer list-none font-medium text-brand-dark flex items-start justify-between gap-4">
            <span>{f.data.question}</span>
            <span class="shrink-0 text-brand transition group-open:rotate-45 text-xl leading-none">+</span>
          </summary>
          <div class="mt-3 text-sm text-muted leading-relaxed border-t border-brand/10 pt-3">
            <p class="whitespace-pre-line">{f.body}</p>
            <p class="mt-2 text-xs text-brand/70">{f.data.category}</p>
          </div>
        </details>
      ))}
    </div>
    <p class="mt-8 text-xs text-muted">※料金・制度・対応範囲は変更される場合があります。最新情報はサービス概要またはお問い合わせでご確認ください。</p>
  </Section>
</BaseLayout>

<script>
  const buttons = document.querySelectorAll('.faq-filter');
  const items = document.querySelectorAll('.faq-item');
  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const cat = btn.getAttribute('data-filter');
      buttons.forEach((b) => b.setAttribute('aria-current', b === btn ? 'true' : 'false'));
      items.forEach((item) => {
        const show = cat === 'すべて' || item.getAttribute('data-category') === cat;
        item.classList.toggle('hidden', !show);
      });
    });
  });
</script>
