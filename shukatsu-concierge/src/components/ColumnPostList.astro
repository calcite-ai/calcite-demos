---
import { withBase } from '../lib/site';
import type { ColumnPost } from '../lib/columns';

interface Props {
  posts: ColumnPost[];
  emptyMessage?: string;
}

const { posts, emptyMessage = 'このカテゴリーの記事はまだありません。' } = Astro.props;
---

{
  posts.length === 0 ? (
    <p class="rounded-2xl border border-dashed border-brand/20 bg-white p-8 text-center text-muted">{emptyMessage}</p>
  ) : (
    <div class="grid gap-4">
      {posts.map((post) => (
        <a
          href={withBase(`/columns/${post.id}/`)}
          class="rounded-2xl border border-brand/10 bg-white p-5 hover:border-brand transition"
        >
          <div class="flex flex-wrap gap-2 text-xs text-muted">
            <span class="rounded-full bg-accent-soft px-2.5 py-1 text-brand-dark font-medium">
              {post.data.category}
            </span>
            <time datetime={post.data.published_date.toISOString()}>
              {post.data.published_date.toISOString().slice(0, 10)}
            </time>
          </div>
          <h2 class="mt-3 text-lg font-bold text-brand-dark">{post.data.title}</h2>
          <p class="mt-2 text-sm text-muted">{post.data.meta_description}</p>
        </a>
      ))}
    </div>
  )
}
