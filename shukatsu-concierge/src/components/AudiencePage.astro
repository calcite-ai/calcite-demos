---
import { withBase } from '../lib/site';
import { breadcrumbJsonLd, faqPageJsonLd } from '../lib/schema';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from './PageHero.astro';
import Section from './Section.astro';
import AnswerLead from './AnswerLead.astro';
import type { AudienceContent } from '../data/audiences';

interface Props {
  content: AudienceContent;
}
const { content } = Astro.props;
const {
  label,
  slug,
  lead,
  summary,
  pains,
  offers,
  scenarios,
  checklist,
  steps,
  relatedCases,
  faqs,
  primaryCta,
} = content;

const path = `/for/${slug}/`;
const desc = `${lead} ${summary[0] ?? ''}`.slice(0, 140);

const jsonLd = [
  breadcrumbJsonLd([{ name: '対象者別' }, { name: label, path }]),
  faqPageJsonLd(faqs, path),
];
---

<BaseLayout title={label} description={desc} jsonLd={jsonLd}>
  <PageHero title={label} lead={lead} crumbs={[{ label: '対象者別' }, { label }]} />

  <div class="mx-auto max-w-6xl px-4 pt-10">
    <AnswerLead title="このページの答え">
      {summary.map((p) => <p>{p}</p>)}
    </AnswerLead>
  </div>

  <Section eyebrow="Challenges" title="現場でよくある課題">
    <ul class="grid gap-3 sm:grid-cols-2">
      {pains.map((p) => (
        <li class="rounded-2xl border border-brand/10 bg-white px-5 py-4 text-muted">{p}</li>
      ))}
    </ul>
  </Section>

  <Section class="bg-white border-y border-brand/5" eyebrow="Support" title="終活コンシェルジュができること">
    <div class="grid gap-4 md:grid-cols-3">
      {offers.map((o) => (
        <article class="rounded-2xl bg-brand-light/60 p-5">
          <h3 class="font-bold text-brand-dark">{o.title}</h3>
          <p class="mt-2 text-sm text-muted leading-relaxed">{o.body}</p>
        </article>
      ))}
    </div>
  </Section>

  <Section eyebrow="Scenarios" title="よくある場面" lead="抽象論ではなく、現場で起きやすい流れでイメージできるようにしました。">
    <div class="space-y-4">
      {scenarios.map((s, i) => (
        <article class="rounded-2xl border border-brand/10 bg-white p-5 md:p-6">
          <p class="text-xs font-semibold tracking-wide text-accent">SCENE {String(i + 1).padStart(2, '0')}</p>
          <h3 class="mt-1 font-bold text-brand-dark">{s.title}</h3>
          <p class="mt-2 text-sm text-muted leading-relaxed">{s.body}</p>
        </article>
      ))}
    </div>
  </Section>

  <Section class="bg-brand-light/40" eyebrow="Before you call" title="相談の前に用意しておくとスムーズなこと">
    <ul class="grid gap-3 sm:grid-cols-2">
      {checklist.map((c) => (
        <li class="flex gap-3 rounded-2xl border border-brand/10 bg-white px-5 py-4 text-sm text-ink/90">
          <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-accent"></span>
          <span>{c}</span>
        </li>
      ))}
    </ul>
  </Section>

  <Section eyebrow="How it works" title="相談・連携の手順">
    <ol class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {steps.map((s, i) => (
        <li class="rounded-2xl border border-brand/10 bg-white p-5">
          <p class="text-xs font-semibold tracking-wide text-accent">STEP {i + 1}</p>
          <h3 class="mt-1 font-bold text-brand-dark">{s.title}</h3>
          <p class="mt-2 text-sm text-muted leading-relaxed">{s.body}</p>
        </li>
      ))}
    </ol>
  </Section>

  <Section class="bg-white border-y border-brand/5" eyebrow="Cases" title="関連する解決事例・資料">
    <div class="grid gap-3 md:grid-cols-3">
      {relatedCases.map((c) => (
        <a href={withBase(c.path)} class="rounded-2xl border border-brand/10 bg-bg p-5 hover:border-brand transition">
          <p class="text-xs font-medium text-accent">{c.note}</p>
          <h3 class="mt-2 font-bold text-brand-dark leading-snug">{c.title}</h3>
          <span class="mt-3 inline-block text-sm text-brand">詳しく見る →</span>
        </a>
      ))}
    </div>
  </Section>

  <Section eyebrow="FAQ" title="よくある質問">
    <div class="space-y-3">
      {faqs.map((f) => (
        <details class="rounded-2xl border border-brand/10 bg-white px-5 py-4">
          <summary class="cursor-pointer font-medium text-brand-dark">{f.question}</summary>
          <p class="mt-3 text-sm text-muted leading-relaxed border-t border-brand/10 pt-3">{f.answer}</p>
        </details>
      ))}
    </div>
    <div class="mt-8 flex flex-wrap gap-3">
      <a href={withBase(primaryCta.href)} class="rounded-full bg-brand px-5 py-2.5 text-sm font-medium text-white hover:bg-brand-dark transition">{primaryCta.label}</a>
      <a href={withBase('/cases/')} class="rounded-full border border-brand/30 px-5 py-2.5 text-sm text-brand">解決事例一覧</a>
      <a href={withBase('/faq/')} class="rounded-full border border-brand/30 px-5 py-2.5 text-sm text-brand">FAQ一覧</a>
      <a href={withBase('/guideline/')} class="rounded-full border border-brand/30 px-5 py-2.5 text-sm text-brand">ガイドラインへの取組み</a>
    </div>
  </Section>
</BaseLayout>
