---
import { withBase } from '../lib/site';
import { breadcrumbJsonLd, faqPageJsonLd } from '../lib/schema';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from './PageHero.astro';
import Section from './Section.astro';
import AnswerLead from './AnswerLead.astro';

export interface AudiencePageProps {
  label: string;
  slug: string;
  lead: string;
  definition: string;
  pains: string[];
  offers: string[];
  faqs: { question: string; answer: string }[];
}

const { label, slug, lead, definition, pains, offers, faqs } = Astro.props as AudiencePageProps;
const path = `/for/${slug}/`;
const desc = `${lead} ${definition}`.slice(0, 120);

const jsonLd = [
  breadcrumbJsonLd([{ name: '対象者別' }, { name: label, path }]),
  faqPageJsonLd(faqs, path),
];
---

<BaseLayout title={label} description={desc} jsonLd={jsonLd}>
  <PageHero title={label} lead={lead} crumbs={[{ label: '対象者別' }, { label }]} />

  <div class="mx-auto max-w-6xl px-4 pt-10">
    <AnswerLead title="このページの答え">
      <p>{definition}</p>
    </AnswerLead>
  </div>

  <Section eyebrow="Challenges" title="現場でよくある課題">
    <ul class="space-y-3">
      {pains.map((p) => (
        <li class="rounded-2xl border border-brand/10 bg-white px-5 py-4 text-muted">{p}</li>
      ))}
    </ul>
  </Section>

  <Section class="bg-white border-y border-brand/5" eyebrow="Support" title="終活コンシェルジュができること">
    <ul class="grid gap-3 md:grid-cols-3">
      {offers.map((o) => (
        <li class="rounded-2xl bg-brand-light/60 p-5 font-medium text-brand-dark">{o}</li>
      ))}
    </ul>
  </Section>

  <Section eyebrow="FAQ" title="よくある質問">
    <div class="space-y-3">
      {faqs.map((f) => (
        <details class="rounded-2xl border border-brand/10 bg-white px-5 py-4">
          <summary class="cursor-pointer font-medium text-brand-dark">{f.question}</summary>
          <p class="mt-3 text-sm text-muted leading-relaxed border-t border-brand/10 pt-3">{f.answer}</p>
        </details>
      ))}
    </div>
    <div class="mt-8 flex flex-wrap gap-3">
      <a href={withBase('/cases/')} class="rounded-full border border-brand/30 px-5 py-2.5 text-sm text-brand">関連する解決事例</a>
      <a href={withBase('/faq/')} class="rounded-full border border-brand/30 px-5 py-2.5 text-sm text-brand">FAQ一覧</a>
      <a href={withBase('/contact/')} class="rounded-full bg-brand px-5 py-2.5 text-sm font-medium text-white">連携・相談する</a>
    </div>
  </Section>
</BaseLayout>
