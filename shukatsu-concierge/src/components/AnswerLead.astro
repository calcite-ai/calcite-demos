---
interface Props {
  title?: string;
  children?: any;
}
const { title = 'このページの要点' } = Astro.props;
---

<aside class="rounded-2xl border border-brand/15 bg-white p-5 md:p-6 shadow-sm">
  <p class="text-xs font-semibold tracking-[0.15em] text-accent uppercase">{title}</p>
  <div class="mt-3 text-[15px] text-ink/90 leading-relaxed space-y-3">
    <slot />
  </div>
</aside>
