---
interface Props {
  id?: string;
  eyebrow?: string;
  title: string;
  lead?: string;
  class?: string;
}
const { id, eyebrow, title, lead, class: className = '' } = Astro.props;
---

<section id={id} class:list={['py-14 md:py-20', className]}>
  <div class="mx-auto max-w-6xl px-4">
    {eyebrow && <p class="text-sm font-medium tracking-wide text-brand">{eyebrow}</p>}
    <h2 class="mt-2 text-2xl md:text-3xl font-bold text-brand-dark tracking-tight">{title}</h2>
    {lead && <p class="mt-3 max-w-3xl text-muted">{lead}</p>}
    <div class="mt-8">
      <slot />
    </div>
  </div>
</section>
